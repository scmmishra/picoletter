<aside class="sticky top-0 grid h-screen py-5 basis-48 font-sans text-sm font-normal">
  <section class="flex min-w-0 flex-col justify-between flex-1 space-y-5">
    <div class="space-y-3">
      <%= render "newsletters/partials/account_switcher" %>
      <nav class="flex-grow text-stone-600 -mx-1.5">
        <ul class="grid gap-1">
          <%= render "newsletters/partials/sidebar_link",
          url: posts_path(@newsletter.slug),
          is_active: current_page?(posts_path(@newsletter.slug)),
          label: "Posts",
          count: @newsletter.posts.published.count %>
          <%= render "newsletters/partials/sidebar_link",
          url: drafts_posts_path(@newsletter.slug),
          is_active: current_page?(drafts_posts_path(@newsletter.slug)),
          label: "Drafts",
          count: @newsletter.posts.draft.count %>
          <%= render "newsletters/partials/sidebar_link",
          url: subscribers_path(@newsletter.slug),
          is_active: controller_name == "subscribers",
          label: "Subscribers",
          count: @newsletter.subscribers.verified.count %>
          <%= render "newsletters/partials/sidebar_link",
          url: labels_path(@newsletter.slug),
          is_active: current_page?(labels_path(@newsletter.slug)),
          label: "Labels" %>
          <% settings_url = @newsletter.can_read?(:general) ? settings_path(@newsletter.slug) : settings_profile_path(@newsletter.slug) %>
          <%= render "newsletters/partials/sidebar_link",
          url: settings_url,
          is_active: current_page?(settings_url),
          label: "Settings" %>
        </ul>
      </nav>
    </div>
    <nav class="text-stone-500 justify-self-end -mx-1.5">
      <div data-controller="callout-stack" class="mb-3">
        <div data-callout-stack-target="nav" class="hidden flex items-center justify-end gap-0.5 mb-1 text-stone-400">
          <button type="button" data-action="callout-stack#prev" class="hover:text-stone-600 transition-colors p-0.5 rounded hover:bg-stone-100">
            <%= lucide_icon("chevron-left", class: "size-3") %>
          </button>
          <button type="button" data-action="callout-stack#next" class="hover:text-stone-600 transition-colors p-0.5 rounded hover:bg-stone-100">
            <%= lucide_icon("chevron-right", class: "size-3") %>
          </button>
        </div>
        <div class="callout-stack-deck" data-callout-stack-target="deck">
          <% pending_invitation = latest_pending_invitation_for_current_user %>
          <% if pending_invitation.present? %>
            <%= render "newsletters/partials/sidebar_callout",
            title: "Invitation pending",
            description: "Join #{pending_invitation.newsletter.title} as a collaborator.",
            button_text: "View invitation",
            button_path: invitation_path(token: pending_invitation.token) %>
          <% end %>
          <%= render "newsletters/partials/sending_domain_banner" %>
          <%= render "newsletters/partials/billing_banner" %>
        </div>
      </div>
      <ul class="grid gap-1">
        <%= render "newsletters/partials/sidebar_link",
        url: newsletter_path(slug: @newsletter.slug),
        icon: "arrow-up-right",
        is_active: false,
        target: "_blank",
        label: "Public view" %>
        <%= render "newsletters/partials/sidebar_link",
        url: auth_logout_path,
        icon: "arrow-right-to-line",
        data: {
          turbo_method: :delete,
        },
        is_active: false,
        label: "Log out" %>
      </ul>
    </nav>
  </section>
</aside>
